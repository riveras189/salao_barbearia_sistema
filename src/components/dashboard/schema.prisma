model GaleriaItem {
  id            String      @id @default(cuid())
  empresaId     String
  titulo        String?
  descricao     String?
  arquivoId     String
  categoria     String?
  ordem         Int         @default(0)
  ativo         Boolean     @default(true)

  empresa       Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  arquivo       Arquivo     @relation("GaleriaArquivo", fields: [arquivoId], references: [id], onDelete: Cascade)

