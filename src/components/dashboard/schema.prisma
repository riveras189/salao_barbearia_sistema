generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TipoArquivo {
  LOGO
  CLIENTE_FOTO
  PROFISSIONAL_FOTO
  PRODUTO_FOTO
  CERTIFICACAO
  GALERIA_SITE
  DOCUMENTO
  BANNER
  SERVICO_IMAGEM
}

enum PapelBaseUsuario {
  ADMIN
  GERENTE
  PROFISSIONAL
  RECEPCIONISTA
}

enum StatusAgendamento {
  AGENDADO
  CONFIRMADO
  EM_ATENDIMENTO
  CONCLUIDO
  CANCELADO
  FALTOU
}

enum OrigemAgendamento {
  INTERNO
  SITE
  WHATSAPP
}

enum StatusComanda {
  ABERTA
  EM_ANDAMENTO
  FECHADA
  CANCELADA
}

enum TipoComandaItem {
  SERVICO
  PRODUTO
}

enum FormaPagamento {
  DINHEIRO
  PIX
  CARTAO_CREDITO
  CARTAO_DEBITO
  MISTO
  FIADO
}

enum TipoMovimentacaoEstoque {
  ENTRADA
  SAIDA
  AJUSTE
  CONSUMO_COMANDA
  PERDA
}

enum OrigemMovimentacaoEstoque {
  MANUAL
  COMPRA
  COMANDA
  AJUSTE
}

enum TipoBloqueioAgenda {
  ALMOCO
  FOLGA
  MEDICO
  MANUTENCAO
  AUSENCIA
  OUTRO
}

enum TipoAlertaCliente {
  ANIVERSARIO
  INADIMPLENTE
  RESTRICAO
  PREFERENCIA
}

enum StatusConta {
  ABERTA
  PARCIAL
  PAGA
  VENCIDA
  CANCELADA
}

enum TipoCaixaMovimento {
  ENTRADA
  SAIDA
}

enum CategoriaCaixaMovimento {
  COMANDA
  DESPESA
  SANGRIA
  SUPRIMENTO
  ESTORNO
  RECEBIMENTO
  OUTRO
}

enum TipoProfissionalDocumento {
  CERTIFICACAO
  CONTRATO
  DOCUMENTO
}

model Empresa {
  id                    String                    @id @default(cuid())
  razaoSocial           String?
  nomeFantasia          String?
  cnpj                  String?
  email                 String?
  telefone              String?
  whatsapp              String?
  cep                   String?
  logradouro            String?
  numero                String?
  complemento           String?
  bairro                String?
  cidade                String?
  uf                    String?
  descricaoPublica      String?
  missao                String?
  valores               String?
  horarioFuncionamento  Json?
  corPrimaria           String?
  corSecundaria         String?
  ativo                 Boolean                   @default(true)
  logoFileId            String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  logo                  Arquivo?                  @relation("EmpresaLogo", fields: [logoFileId], references: [id])

  configuracao          EmpresaConfiguracao?
  agendamentoOnlineConfig AgendamentoOnlineConfig?

  arquivos              Arquivo[]
  usuarios              Usuario[]
  permissoes            Permissao[]
  clientes              Cliente[]
  clienteTags           ClienteTag[]
  profissionais         Profissional[]
  funcionarios          Funcionario[]
  servicoCategorias     ServicoCategoria[]
  servicos              Servico[]
  produtoCategorias     ProdutoCategoria[]
  produtos              Produto[]
  fornecedores          Fornecedor[]
  estoqueMovimentacoes  EstoqueMovimentacao[]
  agendamentos          Agendamento[]
  bloqueiosAgenda       BloqueioAgenda[]
  listasEspera          ListaEspera[]
  comandas              Comanda[]
  recibos               Recibo[]
  caixaMovimentos       CaixaMovimento[]
  contasReceber         ContaReceber[]
  contasPagar           ContaPagar[]
  paginasSite           PaginaSite[]
  bannersSite           BannerSite[]
  galerias              GaleriaItem[]
  depoimentos           Depoimento[]
  auditoriaLogs         AuditoriaLog[]
  loginLogs             LoginLog[]

  @@unique([cnpj])
  @@index([ativo])
}

model EmpresaConfiguracao {
  id                              String    @id @default(cuid())
  empresaId                       String    @unique
  moeda                           String    @default("BRL")
  timezone                        String    @default("America/Sao_Paulo")
  intervaloAgendaMin              Int       @default(30)
  diasAntecedenciaAgendamentoOnline Int     @default(30)
  exigeSinalAgendamento           Boolean   @default(false)
  percentualSinal                 Decimal   @default(0) @db.Decimal(5, 2)
  permiteEncaixe                  Boolean   @default(true)
  notificacaoWhatsappAtiva        Boolean   @default(false)
  notificacaoEmailAtiva           Boolean   @default(false)
  politicaCancelamento            String?
  tema                            String?
  sitePublicado                   Boolean   @default(false)
  createdAt                       DateTime  @default(now())
  updatedAt                       DateTime  @updatedAt

  empresa                         Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
}

model AgendamentoOnlineConfig {
  id                   String    @id @default(cuid())
  empresaId            String    @unique
  ativo                Boolean   @default(false)
  antecedenciaMinHoras Int       @default(2)
  antecedenciaMaxDias  Int       @default(30)
  exigeConfirmacao     Boolean   @default(true)
  exigeSinal           Boolean   @default(false)
  percentualSinal      Decimal   @default(0) @db.Decimal(5, 2)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  empresa              Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
}

model Arquivo {
  id                       String                    @id @default(cuid())
  empresaId                String?
  nomeOriginal             String
  nomeInterno              String
  mimeType                 String
  tamanho                  Int
  url                      String
  categoria                TipoArquivo
  createdAt                DateTime                  @default(now())

  empresa                  Empresa?                   @relation(fields: [empresaId], references: [id], onDelete: SetNull)

  empresasLogo             Empresa[]                  @relation("EmpresaLogo")
  clientesFoto             Cliente[]                  @relation("ClienteFoto")
  profissionaisFoto        Profissional[]             @relation("ProfissionalFoto")
  produtosFoto             Produto[]                  @relation("ProdutoFoto")
  servicoImagens           ServicoImagem[]            @relation("ServicoImagemArquivo")
  profissionalDocumentos   ProfissionalDocumento[]    @relation("ProfissionalDocumentoArquivo")
  banners                  BannerSite[]               @relation("BannerArquivo")
  galerias                 GaleriaItem[]              @relation("GaleriaArquivo")
}

model Usuario {
  id                  String              @id @default(cuid())
  empresaId           String
  nome                String
  email               String?
  login               String
  senhaHash           String
  papelBase           PapelBaseUsuario
  profissionalId      String?             @unique
  funcionarioId       String?             @unique
  ativo               Boolean             @default(true)
  ultimoLoginEm       DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  empresa             Empresa             @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  profissional        Profissional?       @relation(fields: [profissionalId], references: [id], onDelete: SetNull)
  funcionario         Funcionario?        @relation(fields: [funcionarioId], references: [id], onDelete: SetNull)

  permissoes          UsuarioPermissao[]
  auditoriaLogs       AuditoriaLog[]
  loginLogs           LoginLog[]
  agendamentosCriados Agendamento[]       @relation("AgendamentoCriadoPor")
  comandasAbertas     Comanda[]           @relation("ComandaAbertaPor")
  comandasFechadas    Comanda[]           @relation("ComandaFechadaPor")
  pagamentosRecebidos ComandaPagamento[]
  estoqueMovimentos   EstoqueMovimentacao[]
  caixaMovimentos     CaixaMovimento[]
  contasReceberPagamentos ContaReceberPagamento[]
  contasPagarPagamentos   ContaPagarPagamento[]

  @@unique([empresaId, login])
  @@index([empresaId, ativo])
}

model Permissao {
  id          String             @id @default(cuid())
  empresaId   String
  codigo      String
  descricao   String
  modulo      String
  createdAt   DateTime           @default(now())

  empresa     Empresa            @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  usuarios    UsuarioPermissao[]

  @@unique([empresaId, codigo])
  @@index([empresaId, modulo])
}

model UsuarioPermissao {
  id            String      @id @default(cuid())
  usuarioId     String
  permissaoId   String
  permitido     Boolean     @default(true)

  usuario       Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  permissao     Permissao   @relation(fields: [permissaoId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, permissaoId])
}

model LoginLog {
  id          String     @id @default(cuid())
  empresaId   String
  usuarioId   String?
  sucesso     Boolean
  ip          String?
  userAgent   String?
  createdAt   DateTime   @default(now())

  empresa     Empresa    @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  usuario     Usuario?   @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([empresaId, createdAt])
}

model Cliente {
  id                String              @id @default(cuid())
  empresaId         String
  fotoFileId        String?
  nome              String
  cpf               String?
  dataNascimento    DateTime?
  email             String?
  telefone          String?
  whatsapp          String?
  cep               String?
  logradouro        String?
  numero            String?
  complemento       String?
  bairro            String?
  cidade            String?
  uf                String?
  observacoes       String?
  origemCadastro    String?
  ativo             Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  empresa           Empresa             @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  foto              Arquivo?            @relation("ClienteFoto", fields: [fotoFileId], references: [id], onDelete: SetNull)

  tags              ClienteTagItem[]
  alertas           ClienteAlerta[]
  agendamentos      Agendamento[]
  listasEspera      ListaEspera[]
  comandas          Comanda[]
  contasReceber     ContaReceber[]
  avaliacoes        Avaliacao[]

  @@unique([empresaId, cpf])
  @@index([empresaId, nome])
  @@index([empresaId, telefone])
}

model ClienteTag {
  id          String           @id @default(cuid())
  empresaId   String
  nome        String
  cor         String?
  createdAt   DateTime         @default(now())

  empresa     Empresa          @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  itens       ClienteTagItem[]

  @@unique([empresaId, nome])
}

model ClienteTagItem {
  id          String      @id @default(cuid())
  clienteId   String
  tagId       String

  cliente     Cliente     @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  tag         ClienteTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([clienteId, tagId])
}

model ClienteAlerta {
  id          String             @id @default(cuid())
  clienteId   String
  tipo        TipoAlertaCliente
  descricao   String
  ativo       Boolean            @default(true)
  createdAt   DateTime           @default(now())

  cliente     Cliente            @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId, ativo])
}

model Profissional {
  id                  String                    @id @default(cuid())
  empresaId           String
  fotoFileId          String?
  nome                String
  cpf                 String?
  cnpj                String?
  email               String?
  telefone            String?
  whatsapp            String?
  cep                 String?
  logradouro          String?
  numero              String?
  complemento         String?
  bairro              String?
  cidade              String?
  uf                  String?
  dataAdmissao        DateTime?
  dataDemissao        DateTime?
  observacoes         String?
  corAgenda           String?
  ativo               Boolean                   @default(true)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  empresa             Empresa                   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  foto                Arquivo?                  @relation("ProfissionalFoto", fields: [fotoFileId], references: [id], onDelete: SetNull)

  horarios            ProfissionalHorario[]
  servicos            ProfissionalServico[]
  documentos          ProfissionalDocumento[]
  agendamentos        Agendamento[]
  bloqueios           BloqueioAgenda[]
  listasEspera        ListaEspera[]
  comandasPrincipal   Comanda[]                 @relation("ComandaProfissionalPrincipal")
  comandaItens        ComandaItem[]
  avaliacoes          Avaliacao[]
  usuario             Usuario?

  @@unique([empresaId, cpf])
  @@unique([empresaId, cnpj])
  @@index([empresaId, nome])
  @@index([empresaId, ativo])
}

model ProfissionalHorario {
  id               String         @id @default(cuid())
  profissionalId   String
  diaSemana        Int
  horaInicio       String
  horaFim          String
  intervaloInicio  String?
  intervaloFim     String?
  ativo            Boolean        @default(true)

  profissional     Profissional   @relation(fields: [profissionalId], references: [id], onDelete: Cascade)

  @@index([profissionalId, diaSemana, ativo])
}

model ProfissionalServico {
  id                          String         @id @default(cuid())
  profissionalId              String
  servicoId                   String
  comissaoPercentualOverride  Decimal?       @db.Decimal(5, 2)
  valorOverride               Decimal?       @db.Decimal(12, 2)
  duracaoMinOverride          Int?
  ativo                       Boolean        @default(true)

  profissional                Profissional   @relation(fields: [profissionalId], references: [id], onDelete: Cascade)
  servico                     Servico        @relation(fields: [servicoId], references: [id], onDelete: Cascade)

  @@unique([profissionalId, servicoId])
}

model ProfissionalDocumento {
  id            String                    @id @default(cuid())
  profissionalId String
  arquivoId     String
  tipo          TipoProfissionalDocumento
  descricao     String?
  validadeEm    DateTime?
  createdAt     DateTime                  @default(now())

  profissional  Profissional              @relation(fields: [profissionalId], references: [id], onDelete: Cascade)
  arquivo       Arquivo                   @relation("ProfissionalDocumentoArquivo", fields: [arquivoId], references: [id], onDelete: Cascade)
}

model Funcionario {
  id             String      @id @default(cuid())
  empresaId      String
  nome           String
  cpf            String?
  email          String?
  telefone       String?
  cep            String?
  logradouro     String?
  numero         String?
  complemento    String?
  bairro         String?
  cidade         String?
  uf             String?
  dataAdmissao   DateTime?
  dataDemissao   DateTime?
  cargo          String?
  observacoes    String?
  ativo          Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  empresa        Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  usuario        Usuario?

  @@unique([empresaId, cpf])
  @@index([empresaId, nome])
}

model ServicoCategoria {
  id             String      @id @default(cuid())
  empresaId      String
  nome           String
  descricao      String?
  ordemExibicao  Int         @default(0)
  ativo          Boolean     @default(true)

  empresa        Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  servicos       Servico[]

  @@unique([empresaId, nome])
}

model Servico {
  id                         String                 @id @default(cuid())
  empresaId                  String
  categoriaId                String?
  nome                       String
  descricao                  String?
  duracaoMin                 Int
  preco                      Decimal                @db.Decimal(12, 2)
  comissaoPercentualPadrao   Decimal                @default(0) @db.Decimal(5, 2)
  ativo                      Boolean                @default(true)
  exibirNoSite               Boolean                @default(true)
  createdAt                  DateTime               @default(now())
  updatedAt                  DateTime               @updatedAt

  empresa                    Empresa                @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  categoria                  ServicoCategoria?      @relation(fields: [categoriaId], references: [id], onDelete: SetNull)

  profissionais              ProfissionalServico[]
  imagens                    ServicoImagem[]
  agendamentoServicos        AgendamentoServico[]
  comandaItens               ComandaItem[]

  @@index([empresaId, nome])
  @@index([empresaId, ativo])
}

model ServicoImagem {
  id          String                  @id @default(cuid())
  servicoId   String
  arquivoId   String
  ordem       Int                     @default(0)

  servico     Servico                 @relation(fields: [servicoId], references: [id], onDelete: Cascade)
  arquivo     Arquivo                 @relation("ServicoImagemArquivo", fields: [arquivoId], references: [id], onDelete: Cascade)
}

model ProdutoCategoria {
  id          String      @id @default(cuid())
  empresaId   String
  nome        String

  empresa     Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  produtos    Produto[]

  @@unique([empresaId, nome])
}

model Fornecedor {
  id          String      @id @default(cuid())
  empresaId   String
  nome        String
  cnpj        String?
  telefone    String?
  email       String?
  contato     String?
  observacoes String?
  ativo       Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  empresa     Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  produtos    Produto[]
  contasPagar ContaPagar[]

  @@index([empresaId, nome])
}

model Produto {
  id                   String                 @id @default(cuid())
  empresaId            String
  fotoFileId           String?
  categoriaId          String?
  fornecedorId         String?
  nome                 String
  descricao            String?
  sku                  String?
  codigoBarras         String?
  unidade              String?                @default("UN")
  estoqueAtual         Decimal                @default(0) @db.Decimal(12, 3)
  estoqueMinimo        Decimal                @default(0) @db.Decimal(12, 3)
  valorCusto           Decimal                @default(0) @db.Decimal(12, 2)
  valorVenda           Decimal                @default(0) @db.Decimal(12, 2)
  ativo                Boolean                @default(true)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  empresa              Empresa                @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  foto                 Arquivo?               @relation("ProdutoFoto", fields: [fotoFileId], references: [id], onDelete: SetNull)
  categoria            ProdutoCategoria?      @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  fornecedor           Fornecedor?            @relation(fields: [fornecedorId], references: [id], onDelete: SetNull)

  movimentacoes        EstoqueMovimentacao[]
  comandaItens         ComandaItem[]

  @@unique([empresaId, sku])
  @@index([empresaId, nome])
  @@index([empresaId, ativo])
}

model EstoqueMovimentacao {
  id            String                     @id @default(cuid())
  empresaId     String
  produtoId     String
  tipo          TipoMovimentacaoEstoque
  quantidade    Decimal                    @db.Decimal(12, 3)
  valorUnitario Decimal?                   @db.Decimal(12, 2)
  valorTotal    Decimal?                   @db.Decimal(12, 2)
  motivo        String?
  origemTipo    OrigemMovimentacaoEstoque
  origemId      String?
  usuarioId     String?
  createdAt     DateTime                   @default(now())

  empresa       Empresa                    @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  produto       Produto                    @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  usuario       Usuario?                   @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([empresaId, createdAt])
  @@index([produtoId, createdAt])
}

model Agendamento {
  id                  String               @id @default(cuid())
  empresaId           String
  clienteId           String
  profissionalId      String
  inicio              DateTime
  fim                 DateTime
  status              StatusAgendamento    @default(AGENDADO)
  origem              OrigemAgendamento    @default(INTERNO)
  observacoes         String?
  encaixe             Boolean              @default(false)
  comandaId           String?              @unique
  criadoPorUsuarioId  String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  empresa             Empresa              @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente             Cliente              @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  profissional        Profissional         @relation(fields: [profissionalId], references: [id], onDelete: Restrict)
  criadoPorUsuario    Usuario?             @relation("AgendamentoCriadoPor", fields: [criadoPorUsuarioId], references: [id], onDelete: SetNull)
  servicos            AgendamentoServico[]
  comanda             Comanda?             @relation("AgendamentoComanda", fields: [comandaId], references: [id], onDelete: SetNull)

  @@index([empresaId, inicio])
  @@index([profissionalId, inicio, fim])
  @@index([clienteId, inicio])
}

model AgendamentoServico {
  id                         String      @id @default(cuid())
  agendamentoId              String
  servicoId                  String
  nomeSnapshot               String
  duracaoMinSnapshot         Int
  valorSnapshot              Decimal     @db.Decimal(12, 2)
  comissaoPercentualSnapshot Decimal     @db.Decimal(5, 2)
  ordem                      Int         @default(0)

  agendamento                Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)
  servico                    Servico     @relation(fields: [servicoId], references: [id], onDelete: Restrict)

  @@index([agendamentoId, ordem])
}

model BloqueioAgenda {
  id              String               @id @default(cuid())
  empresaId       String
  profissionalId  String
  dataInicio      DateTime
  dataFim         DateTime
  tipo            TipoBloqueioAgenda
  descricao       String?
  cor             String?
  recorrente      Boolean              @default(false)
  ativo           Boolean              @default(true)
  createdAt       DateTime             @default(now())

  empresa         Empresa              @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  profissional    Profissional         @relation(fields: [profissionalId], references: [id], onDelete: Cascade)

  @@index([profissionalId, dataInicio, dataFim])
}

model ListaEspera {
  id                      String         @id @default(cuid())
  empresaId               String
  clienteId               String
  servicoId               String?
  profissionalPreferidoId String?
  dataPreferida           DateTime?
  periodoPreferido        String?
  observacoes             String?
  status                  String?
  createdAt               DateTime       @default(now())

  empresa                 Empresa        @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente                 Cliente        @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  servico                 Servico?       @relation(fields: [servicoId], references: [id], onDelete: SetNull)
  profissionalPreferido   Profissional?  @relation(fields: [profissionalPreferidoId], references: [id], onDelete: SetNull)

  @@index([empresaId, dataPreferida])
}

model Comanda {
  id                    String           @id @default(cuid())
  empresaId             String
  numeroSequencial      Int
  clienteId             String?
  profissionalPrincipalId String?
  agendamentoId         String?          @unique
  status                StatusComanda    @default(ABERTA)
  subtotalServicos      Decimal          @default(0) @db.Decimal(12, 2)
  subtotalProdutos      Decimal          @default(0) @db.Decimal(12, 2)
  descontoValor         Decimal          @default(0) @db.Decimal(12, 2)
  acrescimoValor        Decimal          @default(0) @db.Decimal(12, 2)
  total                 Decimal          @default(0) @db.Decimal(12, 2)
  observacoes           String?
  abertaEm              DateTime         @default(now())
  fechadaEm             DateTime?
  abertaPorUsuarioId    String?
  fechadaPorUsuarioId   String?

  empresa               Empresa          @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente               Cliente?         @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  profissionalPrincipal Profissional?    @relation("ComandaProfissionalPrincipal", fields: [profissionalPrincipalId], references: [id], onDelete: SetNull)
  agendamento           Agendamento?     @relation("AgendamentoComanda")
  abertaPorUsuario      Usuario?         @relation("ComandaAbertaPor", fields: [abertaPorUsuarioId], references: [id], onDelete: SetNull)
  fechadaPorUsuario     Usuario?         @relation("ComandaFechadaPor", fields: [fechadaPorUsuarioId], references: [id], onDelete: SetNull)

  itens                 ComandaItem[]
  pagamentos            ComandaPagamento[]
  recibos               Recibo[]
  avaliacoes            Avaliacao[]

  @@unique([empresaId, numeroSequencial])
  @@index([empresaId, status])
  @@index([clienteId])
}

model ComandaItem {
  id                    String           @id @default(cuid())
  comandaId             String
  tipo                  TipoComandaItem
  servicoId             String?
  produtoId             String?
  profissionalId        String?
  descricao             String
  quantidade            Decimal          @default(1) @db.Decimal(12, 3)
  valorUnitario         Decimal          @db.Decimal(12, 2)
  valorTotal            Decimal          @db.Decimal(12, 2)
  custoUnitario         Decimal?         @db.Decimal(12, 2)
  comissaoPercentual    Decimal?         @db.Decimal(5, 2)
  valorComissao         Decimal?         @db.Decimal(12, 2)
  createdAt             DateTime         @default(now())

  comanda               Comanda          @relation(fields: [comandaId], references: [id], onDelete: Cascade)
  servico               Servico?         @relation(fields: [servicoId], references: [id], onDelete: SetNull)
  produto               Produto?         @relation(fields: [produtoId], references: [id], onDelete: SetNull)
  profissional          Profissional?    @relation(fields: [profissionalId], references: [id], onDelete: SetNull)

  @@index([comandaId])
  @@index([servicoId])
  @@index([produtoId])
}

model ComandaPagamento {
  id                  String           @id @default(cuid())
  comandaId           String
  metodo              FormaPagamento
  valor               Decimal          @db.Decimal(12, 2)
  observacoes         String?
  transacaoExternaId  String?
  pagoEm              DateTime         @default(now())
  recebidoPorUsuarioId String?

  comanda             Comanda          @relation(fields: [comandaId], references: [id], onDelete: Cascade)
  recebidoPorUsuario  Usuario?         @relation(fields: [recebidoPorUsuarioId], references: [id], onDelete: SetNull)

  @@index([comandaId, pagoEm])
}

model Recibo {
  id            String      @id @default(cuid())
  empresaId     String
  comandaId     String
  numero        String
  urlPdf        String?
  enviadoWhatsapp Boolean   @default(false)
  enviadoEmail  Boolean     @default(false)
  createdAt     DateTime    @default(now())

  empresa       Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  comanda       Comanda     @relation(fields: [comandaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, numero])
}

model CaixaMovimento {
  id              String                   @id @default(cuid())
  empresaId       String
  tipo            TipoCaixaMovimento
  categoria       CategoriaCaixaMovimento
  descricao       String
  valor           Decimal                  @db.Decimal(12, 2)
  formaPagamento  FormaPagamento?
  referenciaTipo  String?
  referenciaId    String?
  usuarioId       String?
  dataMovimento   DateTime                 @default(now())
  createdAt       DateTime                 @default(now())

  empresa         Empresa                  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  usuario         Usuario?                 @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([empresaId, dataMovimento])
  @@index([referenciaTipo, referenciaId])
}

model ContaReceber {
  id            String               @id @default(cuid())
  empresaId     String
  clienteId     String?
  descricao     String
  valorOriginal Decimal              @db.Decimal(12, 2)
  valorAberto   Decimal              @db.Decimal(12, 2)
  vencimento    DateTime?
  status        StatusConta          @default(ABERTA)
  origemTipo    String?
  origemId      String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  empresa       Empresa              @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente       Cliente?             @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  pagamentos    ContaReceberPagamento[]

  @@index([empresaId, status, vencimento])
}

model ContaReceberPagamento {
  id              String        @id @default(cuid())
  contaReceberId  String
  valor           Decimal       @db.Decimal(12, 2)
  metodo          FormaPagamento
  pagoEm          DateTime      @default(now())
  usuarioId       String?

  contaReceber    ContaReceber  @relation(fields: [contaReceberId], references: [id], onDelete: Cascade)
  usuario         Usuario?      @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([contaReceberId, pagoEm])
}

model ContaPagar {
  id            String               @id @default(cuid())
  empresaId     String
  fornecedorId  String?
  descricao     String
  valorOriginal Decimal              @db.Decimal(12, 2)
  valorAberto   Decimal              @db.Decimal(12, 2)
  vencimento    DateTime?
  status        StatusConta          @default(ABERTA)
  categoria     String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  empresa       Empresa              @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  fornecedor    Fornecedor?          @relation(fields: [fornecedorId], references: [id], onDelete: SetNull)
  pagamentos    ContaPagarPagamento[]

  @@index([empresaId, status, vencimento])
}

model ContaPagarPagamento {
  id            String         @id @default(cuid())
  contaPagarId  String
  valor         Decimal        @db.Decimal(12, 2)
  pagoEm        DateTime       @default(now())
  metodo        FormaPagamento?
  usuarioId     String?

  contaPagar    ContaPagar     @relation(fields: [contaPagarId], references: [id], onDelete: Cascade)
  usuario       Usuario?       @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([contaPagarId, pagoEm])
}

model PaginaSite {
  id            String      @id @default(cuid())
  empresaId     String
  slug          String
  titulo        String
  conteudoJson  Json
  publicado     Boolean     @default(false)
  updatedAt     DateTime    @updatedAt
  createdAt     DateTime    @default(now())

  empresa       Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, slug])
}

model BannerSite {
