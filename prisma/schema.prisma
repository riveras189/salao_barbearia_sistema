model UsuarioSystemPreference {
  id          String      @id @default(cuid())
  usuarioId   String      @unique
  empresaId   String
  modelId     String
  changedById String?
  changedAt   DateTime    @default(now())
  empresa     Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
