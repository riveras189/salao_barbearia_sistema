model SystemModel {
  id                  String                    @id
  empresaId           String?
  nome                String
  descricao           String
  icone               String?
  ativo               Boolean                   @default(true)
  padrao              Boolean                   @default(false)
  configuracoes       Json
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  empresa             Empresa?                  @relation("EmpresaDefaultSystemModel", fields: [empresaId], references: [id], onDelete: Cascade)
  empresaPreferencias EmpresaSystemPreference[]
  usuarioPreferencias UsuarioSystemPreference[]

  @@index([empresaId, ativo])
  @@index([padrao, ativo])

