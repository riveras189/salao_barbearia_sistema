model ContaPagarPagamento {
  id           String          @id @default(cuid())
  contaPagarId String
  valor        Decimal         @db.Decimal(12, 2)
  pagoEm       DateTime        @default(now())
  metodo       FormaPagamento?
  usuarioId    String?
  createdAt    DateTime        @default(now())

  contaPagar ContaPagar @relation(fields: [contaPagarId], references: [id], onDelete: Cascade)
  usuario    Usuario?   @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([contaPagarId, pagoEm])
  @@index([usuarioId])

  @@map("contapagarpagamento")
}

model ContaPagar {
  id            String      @id @default(cuid())
  empresaId     String
  fornecedorId  String?
  categoriaId   String?
  descricao     String
  valorOriginal Decimal     @db.Decimal(12, 2)
  valorAberto   Decimal     @db.Decimal(12, 2)
  vencimento    DateTime?
  status        StatusConta @default(ABERTA)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  empresa    Empresa               @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  fornecedor Fornecedor?           @relation(fields: [fornecedorId], references: [id], onDelete: SetNull)
  categoria  DespesaCategoria?     @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  pagamentos ContaPagarPagamento[]

  @@index([empresaId, status, vencimento])
  @@index([fornecedorId, vencimento])
  @@index([categoriaId])

  @@map("contapagar")
}

model VendaPdv {
  id             String         @id @default(cuid())
  empresaId      String
  usuarioId      String
  subtotal       Decimal        @db.Decimal(12, 2)
  desconto       Decimal        @default(0) @db.Decimal(12, 2)
