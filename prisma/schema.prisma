  referenciaTipo     OrigemFinanceiraTipo?
  referenciaId       String?
  referencia         String?
  usuarioId          String?
  dataMovimento      DateTime                @default(now())
  createdAt          DateTime                @default(now())

  caixaFechamento CaixaFechamento? @relation(fields: [caixaFechamentoId], references: [id], onDelete: SetNull)
  empresa         Empresa          @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  usuario         Usuario?         @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([empresaId, dataMovimento])
  @@index([empresaId, categoria, dataMovimento])
  @@index([referenciaTipo, referenciaId])
  @@index([usuarioId])

  @@map("caixamovimento")
}

model CaixaFechamento {
  id                  String    @id @default(cuid())
  empresaId           String
  usuarioAberturaId   String?
  usuarioFechamentoId String?
  dataAbertura        DateTime  @default(now())
  dataFechamento      DateTime?
  saldoAbertura       Decimal   @db.Decimal(12, 2) @default(0)
  saldoFechamento     Decimal   @db.Decimal(12, 2) @default(0)
  descricao           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  empresa               Empresa          @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  usuarioAbertura       Usuario?         @relation("CaixaFechamentoAbertura", fields: [usuarioAberturaId], references: [id], onDelete: SetNull)
  usuarioFechamento     Usuario?         @relation("CaixaFechamentoFechamento", fields: [usuarioFechamentoId], references: [id], onDelete: SetNull)
  movimentos            CaixaMovimento[]

  @@index([empresaId, dataAbertura])
  @@index([empresaId, dataFechamento])
  @@unique([empresaId, dataAbertura])

  @@map("caixafechamento")
}

model ContaReceber {
  id            String                @id @default(cuid())
  empresaId     String
  clienteId     String?
  descricao     String
  valorOriginal Decimal               @db.Decimal(12, 2)
  valorAberto   Decimal               @db.Decimal(12, 2)
  vencimento    DateTime?
  status        StatusConta           @default(ABERTA)
  origemTipo    OrigemFinanceiraTipo?
  origemId      String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  empresa    Empresa                 @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente    Cliente?                @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  pagamentos ContaReceberPagamento[]

  @@index([empresaId, status, vencimento])
  @@index([clienteId, vencimento])
  @@index([origemTipo, origemId])

  @@map("contareceber")
}

model ContaReceberPagamento {
  id             String         @id @default(cuid())
  contaReceberId String
  valor          Decimal        @db.Decimal(12, 2)
  metodo         FormaPagamento
  pagoEm         DateTime       @default(now())
  usuarioId      String?
  createdAt      DateTime       @default(now())

  contaReceber ContaReceber @relation(fields: [contaReceberId], references: [id], onDelete: Cascade)
  usuario      Usuario?     @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([contaReceberId, pagoEm])
  @@index([usuarioId])

  @@map("contareceberpagamento")
