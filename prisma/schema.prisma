  quantidade     Decimal  @db.Decimal(12, 3)
  precoUnitario  Decimal  @db.Decimal(12, 2)
  subtotal       Decimal  @db.Decimal(12, 2)

  vendaPdv VendaPdv @relation(fields: [vendaPdvId], references: [id], onDelete: Cascade)
  produto  Produto   @relation(fields: [produtoId], references: [id], onDelete: Restrict)

  @@index([vendaPdvId])
  @@index([produtoId])

  @@map("vendapdvitem")
}

model DespesaCategoria {
