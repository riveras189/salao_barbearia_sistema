  usuario     Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  changedBy   Usuario?    @relation("UsuarioSystemPreferenceChangedBy", fields: [changedById], references: [id])

  @@index([empresaId, changedAt])
  @@index([modelId])

  @@map("usuariosystempreference")
}

model EmpresaSystemPreference {
  id          String      @id @default(cuid())
  empresaId   String      @unique
  modelId     String
  changedById String?
  changedAt   DateTime    @default(now())
  empresa     Empresa     @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  model       SystemModel @relation(fields: [modelId], references: [id])
  changedBy   Usuario?    @relation("EmpresaSystemPreferenceChangedBy", fields: [changedById], references: [id])

  @@index([modelId])
  @@index([changedAt])

  @@map("empresasystempreference")
}

model AuditoriaLog {
